# agnosys/syscalls.cyr — Linux x86_64 syscall wrappers
# Usage: include "lib/agnosys/syscalls.cyr"
#
# Cyrius re-implementation of agnosys syscall bindings.
# Constants use enums to avoid gvar_toks overflow (64 slot limit).

# ================================================================
# Syscall numbers (x86_64)
# ================================================================
enum SysNr {
    SYS_READ = 0;
    SYS_WRITE = 1;
    SYS_OPEN = 2;
    SYS_CLOSE = 3;
    SYS_STAT = 4;
    SYS_FSTAT = 5;
    SYS_LSEEK = 8;
    SYS_MMAP = 9;
    SYS_BRK = 12;
    SYS_RT_SIGPROCMASK = 14;
    SYS_IOCTL = 16;
    SYS_ACCESS = 21;
    SYS_PIPE = 22;
    SYS_DUP = 32;
    SYS_DUP2 = 33;
    SYS_PAUSE = 34;
    SYS_GETPID = 39;
    SYS_FORK = 57;
    SYS_EXECVE = 59;
    SYS_EXIT = 60;
    SYS_WAIT4 = 61;
    SYS_KILL = 62;
    SYS_UNAME = 63;
    SYS_FCNTL = 72;
    SYS_GETCWD = 79;
    SYS_CHDIR = 80;
    SYS_MKDIR = 83;
    SYS_RMDIR = 84;
    SYS_UNLINK = 87;
    SYS_CHMOD = 90;
    SYS_GETUID = 102;
    SYS_GETGID = 104;
    SYS_SETUID = 105;
    SYS_SETGID = 106;
    SYS_GETEUID = 107;
    SYS_GETEGID = 108;
    SYS_GETPPID = 110;
    SYS_SETSID = 112;
    SYS_SETGROUPS = 116;
    SYS_SYNC = 162;
    SYS_MOUNT = 165;
    SYS_UMOUNT2 = 166;
    SYS_REBOOT = 169;
    SYS_EPOLL_WAIT = 232;
    SYS_EPOLL_CTL = 233;
    SYS_WAITID = 247;
    SYS_TIMERFD_CREATE = 283;
    SYS_TIMERFD_SETTIME = 286;
    SYS_SIGNALFD4 = 289;
    SYS_EPOLL_CREATE1 = 291;
    SYS_CLONE = 56;
    SYS_MUNMAP = 11;
    SYS_FUTEX = 202;
    SYS_GETTID = 186;
    SYS_SET_TID_ADDRESS = 218;
    SYS_EXIT_GROUP = 231;
}

# ================================================================
# Clone flags (for thread creation)
# ================================================================
