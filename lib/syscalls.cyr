    TFD_NONBLOCK = 2048;
    TFD_CLOEXEC = 524288;
}

enum WaitFlag {
    WNOHANG = 1;
    WUNTRACED = 2;
}

enum SfdFlag {
    SFD_NONBLOCK = 2048;
    SFD_CLOEXEC = 524288;
}

enum RebootCmd {
    RB_POWER_OFF = 0x4321FEDC;
    RB_AUTOBOOT = 0x01234567;
    RB_HALT_SYSTEM = 0xCDEF0123;
}

enum Errno {
    EPERM = 1;
    ENOENT = 2;
    ESRCH = 3;
    EINTR = 4;
    EIO = 5;
    ENXIO = 6;
    EAGAIN = 11;
    EACCES = 13;
    EBUSY = 16;
    EEXIST = 17;
    ENOTDIR = 20;
    EISDIR = 21;
    EINVAL = 22;
    ENFILE = 23;
    EMFILE = 24;
    ENOSPC = 28;
    ECHILD = 10;
}

# Standard fds
enum StdFd {
    STDIN_FD = 0;
    STDOUT_FD = 1;
    STDERR_FD = 2;
}

# Reboot magic
var LINUX_REBOOT_MAGIC1 = 0xFEE1DEAD;
var LINUX_REBOOT_MAGIC2 = 672274793;

# ================================================================
# Syscall wrappers
# ================================================================

# File operations
fn sys_open(path, flags, mode) {
    return syscall(SYS_OPEN, path, flags, mode);
}

# Close a file descriptor.
fn sys_close(fd) {
    return syscall(SYS_CLOSE, fd);
}

# Read bytes from fd into buffer. Returns bytes read.
fn sys_read(fd, buf, count) {
    return syscall(SYS_READ, fd, buf, count);
}

# Write bytes from buffer to fd. Returns bytes written.
fn sys_write(fd, buf, count) {
    return syscall(SYS_WRITE, fd, buf, count);
}

# Duplicate fd oldfd to newfd.
fn sys_dup2(oldfd, newfd) {
    return syscall(SYS_DUP2, oldfd, newfd);
}

# Create a directory at path with given mode.
fn sys_mkdir(path, mode) {
    return syscall(SYS_MKDIR, path, mode);
}

# Remove an empty directory.
fn sys_rmdir(path) {
    return syscall(SYS_RMDIR, path);
}

# Delete a file.
fn sys_unlink(path) {
    return syscall(SYS_UNLINK, path);
}

# Change file permissions.
fn sys_chmod(path, mode) {
    return syscall(SYS_CHMOD, path, mode);
}

# Check file access permissions.
fn sys_access(path, mode) {
    return syscall(SYS_ACCESS, path, mode);
}

# Process operations
fn sys_fork() {
    return syscall(SYS_FORK);
}

# Terminate process with exit code.
fn sys_exit(code) {
    syscall(SYS_EXIT, code);
    return 0;
}

# execve: replace process image. argv and envp are null-terminated arrays of pointers.
fn sys_execve(path, argv, envp) {
    return syscall(SYS_EXECVE, path, argv, envp);
}

# pipe: create pipe, fds[0]=read end, fds[1]=write end
fn sys_pipe(fds) {
    return syscall(SYS_PIPE, fds);
}

# Get current process ID.
fn sys_getpid() {
    return syscall(SYS_GETPID);
}

# waitpid via wait4 with rusage=NULL
fn sys_waitpid(pid, status_ptr, options) {
    return syscall(SYS_WAIT4, pid, status_ptr, options, 0);
}

# Wait status macros
fn WIFEXITED(status) {
    if ((status & 0x7F) == 0) { return 1; }
    return 0;
}

fn WEXITSTATUS(status) {
    return (status >> 8) & 0xFF;
}

# Utility
fn is_err(ret) {
    if (ret < 0) { return 1; }
    return 0;
}

# err_code syscall wrapper.
fn err_code(ret) {
    return 0 - ret;
}
