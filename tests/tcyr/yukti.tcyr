    return 0;
}

fn test_default_mount_point() {
    var info = device_info_new(device_id_new_cstr("t"), str_from("/dev/sdb1"), DC_USB_STORAGE);
    di_set_label(info, str_from("MY_USB"));
    var mp = default_mount_point(info);
    assert(str_eq_cstr(mp, "/run/media/MY_USB"), "default mp label");
    return 0;
}

fn test_default_mount_point_no_label() {
    var info = device_info_new(device_id_new_cstr("block:sdb1"), str_from("/dev/sdb1"), DC_USB_STORAGE);
    var mp = default_mount_point(info);
    assert(str_starts_with(mp, "/run/media/"), "default mp prefix");
    return 0;
}

fn test_mount_options_new() {
    var opts = mount_options_new();
    assert_eq(load64(opts), 0, "opts no mp");
    assert_eq(load64(opts + 8), 0, "opts not ro");
    assert_eq(load64(opts + 24), 0, "opts no fstype");
    return 0;
}

fn test_filesystem_usage_root() {
    var r = filesystem_usage("/");
    assert(is_ok(r), "fs usage root ok");
    var u = payload(r);
    assert(load64(u) > 0, "total > 0");
    assert(load64(u + 16) > 0, "avail > 0");
    return 0;
}

fn test_filesystem_usage_nonexistent() {
    var r = filesystem_usage("/nonexistent_yukti_path");
    assert(is_ok(r) == 0, "fs usage nonexistent err");
    return 0;
}

