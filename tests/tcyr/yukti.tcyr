    return 0;
}

fn test_readonly_device() {
    var props = map_new();
    map_set(props, "ID_FS_READONLY", str_from("1"));
    var e = udev_event_new(str_from("add"), str_from("/sys/block/sda"),
    str_from("/dev/sda"), str_from("block"), str_from("disk"), props);
    var caps = extract_capabilities(e, DC_BLOCK_INTERNAL);
    assert(has_cap(caps, CAP_READ), "ro has read");
    assert(has_cap(caps, CAP_WRITE) == 0, "ro no write");
