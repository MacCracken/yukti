# yukti test suite — comprehensive
# Tests all modules: error, device, event, storage, optical, udev, udev_rules, linux
# Target: match Rust test coverage (229 tests)

include "src/lib.cyr"
include "lib/assert.cyr"

# ===================================================================
# Error tests (17 in Rust)
# ===================================================================

fn test_error_device_not_found() {
    test_group("error");
    var e = yukti_err_new(ERR_DEVICE_NOT_FOUND, str_from("usb-001"));
    assert_eq(yukti_err_kind(e), ERR_DEVICE_NOT_FOUND, "err kind");
    assert(str_eq_cstr(yukti_err_detail(e), "usb-001"), "err detail");
    assert_eq(yukti_err_context(e), 0, "err no context");
    return 0;
}

fn test_error_device_busy() {
    var e = yukti_err_new(ERR_DEVICE_BUSY, str_from("/dev/sdb1"));
    assert_eq(yukti_err_kind(e), ERR_DEVICE_BUSY, "busy kind");
    assert(str_contains_cstr(yukti_err_detail(e), "/dev/sdb1"), "busy detail");
    return 0;
}

fn test_error_mount_failed() {
    var e = yukti_err_new_ctx(ERR_MOUNT_FAILED, str_from("bad superblock"), str_from("/dev/sdb1"));
    assert_eq(yukti_err_kind(e), ERR_MOUNT_FAILED, "mount kind");
    assert(str_eq_cstr(yukti_err_detail(e), "bad superblock"), "mount detail");
    assert(str_eq_cstr(yukti_err_context(e), "/dev/sdb1"), "mount context");
    return 0;
}

fn test_error_unmount_failed() {
    var e = yukti_err_new_ctx(ERR_UNMOUNT_FAILED, str_from("device busy"), str_from("/mnt/usb"));
    assert_eq(yukti_err_kind(e), ERR_UNMOUNT_FAILED, "unmount kind");
    assert(str_contains_cstr(yukti_err_detail(e), "device busy"), "unmount detail");
    return 0;
}

fn test_error_eject_failed() {
    var e = yukti_err_new_ctx(ERR_EJECT_FAILED, str_from("tray locked"), str_from("/dev/sr0"));
    assert_eq(yukti_err_kind(e), ERR_EJECT_FAILED, "eject kind");
    assert(str_contains_cstr(yukti_err_detail(e), "tray locked"), "eject detail");
    return 0;
}

fn test_error_tray_failed() {
    var e = yukti_err_new(ERR_TRAY_FAILED, str_from("mechanical error"));
    assert(str_contains_cstr(yukti_err_detail(e), "mechanical error"), "tray detail");
    return 0;
}

fn test_error_permission_denied() {
    var e = yukti_err_new_ctx(ERR_PERMISSION_DENIED, str_from("mount"), str_from("/dev/sda"));
    var sb = str_builder_new();
    yukti_err_to_str(e, sb);
    var s = str_builder_build(sb);
    assert(str_contains_cstr(s, "permission denied"), "perm kind str");
    assert(str_contains_cstr(s, "mount"), "perm detail str");
    assert(str_contains_cstr(s, "/dev/sda"), "perm context str");
    return 0;
}

fn test_error_udev() {
    var e = yukti_err_new(ERR_UDEV, str_from("netlink failed"));
    assert(str_contains_cstr(yukti_err_detail(e), "netlink failed"), "udev detail");
    return 0;
}

fn test_error_no_media() {
    var e = yukti_err_new(ERR_NO_MEDIA, str_from("/dev/sr0"));
    assert_eq(yukti_err_kind(e), ERR_NO_MEDIA, "no media kind");
    return 0;
}

