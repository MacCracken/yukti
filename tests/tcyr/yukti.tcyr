fn test_error_already_mounted() {
    var e = yukti_err_new_ctx(ERR_ALREADY_MOUNTED, str_from("/dev/sdb1"), str_from("/mnt/usb"));
    assert_eq(yukti_err_kind(e), ERR_ALREADY_MOUNTED, "already mounted kind");
    return 0;
}

