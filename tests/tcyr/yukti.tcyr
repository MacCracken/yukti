fn make_usb_udev_event() {
    var props = map_new();
    map_set(props, "ID_BUS", str_from("usb"));
    map_set(props, "ID_VENDOR", str_from("SanDisk"));
    map_set(props, "ID_MODEL", str_from("Cruzer_Blade"));
    map_set(props, "ID_SERIAL_SHORT", str_from("ABC123"));
    map_set(props, "ID_FS_TYPE", str_from("vfat"));
    map_set(props, "ID_FS_LABEL", str_from("MYUSB"));
    map_set(props, "ID_USB_DRIVER", str_from("usb-storage"));
    map_set(props, "ID_PART_ENTRY_SIZE", str_from("31457280"));
    return udev_event_new(str_from("add"), str_from("/sys/devices/pci0000:00/usb1/1-1/block/sdb/sdb1"),
    str_from("/dev/sdb1"), str_from("block"), str_from("partition"), props);
}

fn make_optical_udev_event() {
    var props = map_new();
    map_set(props, "ID_CDROM", str_from("1"));
    map_set(props, "ID_CDROM_DVD", str_from("1"));
    map_set(props, "ID_CDROM_DVD_RW", str_from("1"));
    map_set(props, "ID_FS_TYPE", str_from("iso9660"));
    map_set(props, "ID_FS_LABEL", str_from("MOVIE_DISC"));
    return udev_event_new(str_from("change"), str_from("/sys/devices/pci0000:00/ata1/host0/block/sr0"),
    str_from("/dev/sr0"), str_from("block"), str_from("disk"), props);
}

fn test_classify_usb() {
    test_group("udev");
    assert_eq(classify_device(make_usb_udev_event()), DC_USB_STORAGE, "cls usb");
    return 0;
}

fn test_classify_optical() {
    assert_eq(classify_device(make_optical_udev_event()), DC_OPTICAL, "cls opt");
    return 0;
}

fn test_classify_sd() {
    var props = map_new();
