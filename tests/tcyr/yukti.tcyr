fn test_classify_unknown() {
    var e = udev_event_new(str_from("add"), str_from("/sys/something"),
    str_from("/dev/something"), str_from("net"), 0, map_new());
    assert_eq(classify_device(e), DC_UNKNOWN, "cls unk");
    return 0;
}

fn test_extract_capabilities_usb() {
    var usb = make_usb_udev_event();
    var caps = extract_capabilities(usb, DC_USB_STORAGE);
    assert(has_cap(caps, CAP_READ), "usb cap read");
    assert(has_cap(caps, CAP_WRITE), "usb cap write");
    assert(has_cap(caps, CAP_REMOVABLE), "usb cap rem");
    assert(has_cap(caps, CAP_HOTPLUG), "usb cap hot");
    assert(has_cap(caps, CAP_EJECT), "usb cap eject");
    return 0;
}

fn test_extract_capabilities_optical() {
    var opt = make_optical_udev_event();
    var caps = extract_capabilities(opt, DC_OPTICAL);
    assert(has_cap(caps, CAP_MEDIA_CHANGE), "opt cap media");
    assert(has_cap(caps, CAP_TRAY_CONTROL), "opt cap tray");
    assert(has_cap(caps, CAP_BURN), "opt cap burn");
    assert(has_cap(caps, CAP_REMOVABLE), "opt cap rem");
    return 0;
}

fn test_classify_and_extract() {
    var usb = make_usb_udev_event();
    var ce = classify_and_extract(usb);
    assert_eq(load64(ce), DC_USB_STORAGE, "cae class");
    assert(has_cap(load64(ce + 8), CAP_READ), "cae cap read");
    return 0;
}

fn test_device_info_from_udev() {
    var usb = make_usb_udev_event();
    var r = device_info_from_udev(usb);
    assert(is_ok(r), "udev info ok");
    var info = payload(r);
    assert_eq(di_class(info), DC_USB_STORAGE, "udev cls");
    assert(str_eq_cstr(di_vendor(info), "SanDisk"), "udev vendor");
    assert(str_eq_cstr(di_model(info), "Cruzer_Blade"), "udev model");
    assert(str_eq_cstr(di_serial(info), "ABC123"), "udev serial");
    assert(str_eq_cstr(di_label(info), "MYUSB"), "udev label");
    assert(str_eq_cstr(di_fs_type(info), "vfat"), "udev fstype");
    assert_eq(di_size_bytes(info), 31457280 * 512, "udev size");
    return 0;
}

fn test_device_info_from_udev_optical() {
    var opt = make_optical_udev_event();
    var r = device_info_from_udev(opt);
    assert(is_ok(r), "udev opt ok");
    var info = payload(r);
    assert_eq(di_class(info), DC_OPTICAL, "udev opt cls");
    assert(str_eq_cstr(di_label(info), "MOVIE_DISC"), "udev opt label");
    return 0;
}

fn test_no_dev_path_error() {
    var e = udev_event_new(str_from("add"), str_from("/sys/x"), 0,
    str_from("block"), 0, map_new());
    var r = device_info_from_udev(e);
    assert(is_ok(r) == 0, "no devpath err");
    return 0;
}

fn test_udev_event_actions() {
    var add = udev_event_new(str_from("add"), str_from("/sys/x"), str_from("/dev/x"), str_from("block"), 0, map_new());
    assert(udev_event_is_add(add), "ue add");
    assert(udev_event_is_remove(add) == 0, "ue not rm");
    assert(udev_event_is_change(add) == 0, "ue not chg");

    var rem = udev_event_new(str_from("remove"), str_from("/sys/x"), str_from("/dev/x"),
    str_from("block"), 0, map_new());
    assert(udev_event_is_remove(rem), "ue rm");

    var chg = udev_event_new(str_from("change"), str_from("/sys/x"), str_from("/dev/x"),
    str_from("block"), 0, map_new());
    assert(udev_event_is_change(chg), "ue chg");
    return 0;
}

fn test_udev_event_property() {
    var props = map_new();
    map_set(props, "ID_BUS", str_from("usb"));
    var e = udev_event_new(str_from("add"), str_from("/sys/x"), str_from("/dev/x"), str_from("block"), 0, props);
    var bus = udev_event_property(e, "ID_BUS");
    assert(bus != 0, "prop found");
    assert(str_eq_cstr(bus, "usb"), "prop val");
    assert_eq(udev_event_property(e, "NONEXISTENT"), 0, "prop miss");
    return 0;
}

fn test_parse_uevent_usb_add() {
    # Build uevent buffer with explicit null separators
    var buf[256];
    var pos = 0;
    # "add@/devices/pci/usb/block/sdb" + null
    memcpy(&buf, "add@/devices/pci/usb/block/sdb", 30);
    store8(&buf + 30, 0); pos = 31;
    # "ACTION=add" + null
    memcpy(&buf + pos, "ACTION=add", 10);
    store8(&buf + pos + 10, 0); pos = pos + 11;
    # "DEVPATH=/devices/pci/usb/block/sdb" + null
    memcpy(&buf + pos, "DEVPATH=/devices/pci/usb/block/sdb", 34);
    store8(&buf + pos + 34, 0); pos = pos + 35;
    # "SUBSYSTEM=block" + null
    memcpy(&buf + pos, "SUBSYSTEM=block", 15);
    store8(&buf + pos + 15, 0); pos = pos + 16;
    # "DEVTYPE=disk" + null
    memcpy(&buf + pos, "DEVTYPE=disk", 12);
    store8(&buf + pos + 12, 0); pos = pos + 13;
    # "DEVNAME=sdb" + null
    memcpy(&buf + pos, "DEVNAME=sdb", 11);
    store8(&buf + pos + 11, 0); pos = pos + 12;

    var e = parse_uevent(&buf, pos);
    assert(e != 0, "parsed ok");
    assert(udev_event_is_add(e), "parsed add");
    assert(str_eq_cstr(ue_subsystem(e), "block"), "parsed subsys");
    return 0;
}

fn test_parse_uevent_remove() {
    var buf[128];
    var pos = 0;
    memcpy(&buf, "remove@/devices/usb/block/sdb", 28);
    store8(&buf + 28, 0); pos = 29;
    memcpy(&buf + pos, "ACTION=remove", 13);
    store8(&buf + pos + 13, 0); pos = pos + 14;
    memcpy(&buf + pos, "DEVPATH=/devices/usb/block/sdb", 30);
    store8(&buf + pos + 30, 0); pos = pos + 31;
    memcpy(&buf + pos, "SUBSYSTEM=block", 15);
    store8(&buf + pos + 15, 0); pos = pos + 16;
    memcpy(&buf + pos, "DEVNAME=sdb", 11);
    store8(&buf + pos + 11, 0); pos = pos + 12;

    var e = parse_uevent(&buf, pos);
    assert(e != 0, "parsed rm");
    assert(udev_event_is_remove(e), "parsed rm action");
    return 0;
}

fn test_parse_uevent_empty() {
    assert_eq(parse_uevent("", 0), 0, "empty null");
    return 0;
}

fn test_parse_uevent_garbage() {
    var garbage = "asdfjkl;qwerty";
    assert_eq(parse_uevent(garbage, 14), 0, "garbage null");
    return 0;
}

fn test_parse_uevent_no_header() {
    var buf[128];
    var pos = 0;
    memcpy(&buf, "ACTION=add", 10);
    store8(&buf + 10, 0); pos = 11;
    memcpy(&buf + pos, "DEVPATH=/devices/block/sda", 25);
    store8(&buf + pos + 25, 0); pos = pos + 26;
    memcpy(&buf + pos, "SUBSYSTEM=block", 15);
    store8(&buf + pos + 15, 0); pos = pos + 16;
    memcpy(&buf + pos, "DEVNAME=sda", 11);
    store8(&buf + pos + 11, 0); pos = pos + 12;

    var e = parse_uevent(&buf, pos);
    assert(e != 0, "no header parsed");
    assert(udev_event_is_add(e), "no header action");
    return 0;
}

fn test_udev_event_to_device_event() {
    var usb = make_usb_udev_event();
    var de = udev_event_to_device_event(usb);
    assert(de != 0, "ue->de ok");
    assert(device_event_is_attach(de), "ue->de attach");
    assert(de_device_info(de) != 0, "ue->de has info");
    return 0;
}

fn test_udev_event_to_device_event_remove() {
    var e = udev_event_new(str_from("remove"), str_from("/sys/block/sdb"), str_from("/dev/sdb"),
    str_from("block"), str_from("disk"), map_new());
    var de = udev_event_to_device_event(e);
    assert(de != 0, "rm->de ok");
    assert(device_event_is_detach(de), "rm->de detach");
    assert_eq(de_device_info(de), 0, "rm->de no info");
    return 0;
}

fn test_udev_event_to_device_event_unknown() {
    var e = udev_event_new(str_from("bind"), str_from("/sys/x"), str_from("/dev/x"),
    str_from("block"), 0, map_new());
