fn test_detect_disc_type_all() {
    assert_eq(detect_disc_type("cd", 1, 0), DT_CD_AUDIO, "det cd audio");
    assert_eq(detect_disc_type("cd-rom", 0, 1), DT_CD_DATA, "det cd data");
    assert_eq(detect_disc_type("cd-rom", 0, 1), DT_CD_DATA, "det cd-rom data");
    assert_eq(detect_disc_type("cd", 1, 1), DT_CD_MIXED, "det cd mixed");
    assert_eq(detect_disc_type("dvd-rom", 0, 1), DT_DVD_ROM, "det dvd");
    assert_eq(detect_disc_type("dvd", 0, 1), DT_DVD_ROM, "det dvd2");
    assert_eq(detect_disc_type("dvd-r", 0, 1), DT_DVD_WRITABLE, "det dvd-r");
    assert_eq(detect_disc_type("dvd-rw", 0, 1), DT_DVD_WRITABLE, "det dvd-rw");
    assert_eq(detect_disc_type("dvd+r", 0, 1), DT_DVD_WRITABLE, "det dvd+r");
    assert_eq(detect_disc_type("dvd+rw", 0, 1), DT_DVD_WRITABLE, "det dvd+rw");
    assert_eq(detect_disc_type("dvd-video", 0, 1), DT_DVD_VIDEO, "det dvd-v");
    assert_eq(detect_disc_type("bd", 0, 1), DT_BLURAY, "det bd");
    assert_eq(detect_disc_type("blu-ray", 0, 1), DT_BLURAY, "det blu-ray");
    assert_eq(detect_disc_type("bd-rom", 0, 1), DT_BLURAY, "det bd-rom");
    assert_eq(detect_disc_type("bd-video", 0, 1), DT_BLURAY_VIDEO, "det bd-video");
    assert_eq(detect_disc_type("blank", 0, 0), DT_BLANK, "det blank");
    assert_eq(detect_disc_type("no_disc", 0, 0), DT_BLANK, "det no_disc");
    assert_eq(detect_disc_type("floppy", 0, 0), DT_UNKNOWN, "det unknown");
    assert_eq(detect_disc_type("", 0, 0), DT_UNKNOWN, "det empty");
    return 0;
}

fn test_detect_case_insensitive() {
    assert_eq(detect_disc_type("CD", 1, 0), DT_CD_AUDIO, "ci CD");
    assert_eq(detect_disc_type("DVD-ROM", 0, 1), DT_DVD_ROM, "ci DVD-ROM");
    assert_eq(detect_disc_type("BD", 0, 1), DT_BLURAY, "ci BD");
    assert_eq(detect_disc_type("BLANK", 0, 0), DT_BLANK, "ci BLANK");
    return 0;
}

# 2.1.0: dual-layer / dual-sided DVD + Blu-ray capacity variants
fn test_detect_disc_type_layered() {
    assert_eq(detect_disc_type("dvd-r-dl", 0, 1), DT_DVD_WRITABLE_DL, "DL DVD-R");
    assert_eq(detect_disc_type("dvd+r-dl", 0, 1), DT_DVD_WRITABLE_DL, "DL DVD+R");
    assert_eq(detect_disc_type("dvd-r_dl", 0, 1), DT_DVD_WRITABLE_DL, "DL DVD-R underscore");
    assert_eq(detect_disc_type("dvd-rom-dl", 0, 1), DT_DVD_ROM_DL, "DL DVD-ROM");
    assert_eq(detect_disc_type("dvd-ds", 0, 1), DT_DVD_DUAL_SIDED, "DS DVD");
    assert_eq(detect_disc_type("dvd-dual-sided", 0, 1), DT_DVD_DUAL_SIDED, "DS DVD long");
    assert_eq(detect_disc_type("bd-dl", 0, 1), DT_BLURAY_DL, "DL BD");
    assert_eq(detect_disc_type("bd-r-dl", 0, 1), DT_BLURAY_DL, "DL BD-R");
    assert_eq(detect_disc_type("bdxl", 0, 1), DT_BLURAY_XL, "BDXL");
    assert_eq(detect_disc_type("bd-xl", 0, 1), DT_BLURAY_XL, "BD-XL");
    # case-insensitive
    assert_eq(detect_disc_type("DVD-R-DL", 0, 1), DT_DVD_WRITABLE_DL, "DL case insensitive");
    return 0;
}

fn test_disc_type_nominal_sectors() {
    assert(disc_type_nominal_sectors(DT_CD_AUDIO) == 333000, "CD sectors");
    assert(disc_type_nominal_sectors(DT_DVD_ROM) == 2295104, "DVD SL sectors");
    assert(disc_type_nominal_sectors(DT_DVD_WRITABLE_DL) == 4148608, "DVD DL sectors");
    assert(disc_type_nominal_sectors(DT_DVD_DUAL_SIDED) == 4590208, "DVD DS sectors");
    assert(disc_type_nominal_sectors(DT_BLURAY) == 12219392, "BD SL sectors");
    assert(disc_type_nominal_sectors(DT_BLURAY_DL) == 24438784, "BD DL sectors");
    assert(disc_type_nominal_sectors(DT_BLURAY_XL) == 48877568, "BD XL sectors");
    assert(disc_type_nominal_sectors(DT_UNKNOWN) == 0, "unknown = 0");
    return 0;
}

# 2.1.0: audio CD ripping input validation. Can't exercise the
# ioctl itself without hardware; validate the bounds checks that
# guard it.
fn test_read_audio_sectors_rejects_bad_input() {
    var small_buf[32];
    # nframes <= 0
    assert(is_ok(read_audio_sectors("/dev/sr0", 0, 0, &small_buf, 32)) == 0,
    "0 frames rejected");
    assert(is_ok(read_audio_sectors("/dev/sr0", 0, 0 - 5, &small_buf, 32)) == 0,
    "negative frames rejected");
    # Buffer too small (1 frame = 2352 bytes, buf = 32)
    assert(is_ok(read_audio_sectors("/dev/sr0", 0, 1, &small_buf, 32)) == 0,
    "undersized buf rejected");
    return 0;
}

fn test_read_audio_track_rejects_data_track() {
    # Build a TOC entry marked as data
    var data_entry = toc_entry_new(1, TT_DATA, 0, 1000, 0);
    var buf[4096];
    assert(is_ok(read_audio_track("/dev/sr0", data_entry, &buf, 4096)) == 0,
    "data track rejected");
    # Zero-length audio track returns Ok(0) without any ioctl
    var empty_entry = toc_entry_new(1, TT_AUDIO, 0, 0, 0);
    var r = read_audio_track("/dev/sr0", empty_entry, &buf, 4096);
    assert(is_ok(r), "empty audio track ok");
    assert(payload(r) == 0, "empty audio track read 0 bytes");
    return 0;
}

fn test_disc_type_layered_predicates() {
    # Data predicate covers every layered variant
    assert(disc_type_has_data(DT_DVD_WRITABLE_DL), "DL has data");
    assert(disc_type_has_data(DT_DVD_DUAL_SIDED), "DS has data");
    assert(disc_type_has_data(DT_BLURAY_XL), "XL has data");
    # Writable predicate catches DL writable
    assert(disc_type_is_writable(DT_DVD_WRITABLE_DL), "DL writable");
    # Display names include the layer designation
    assert(str_eq_cstr(str_from(disc_type_to_str(DT_DVD_WRITABLE_DL)),
    "DVD±R DL (Dual Layer)"), "DL display");
    return 0;
}

fn test_classify_toc_tracks() {
    assert_eq(classify_toc_tracks(1, 0), DT_CD_AUDIO, "toc audio");
    assert_eq(classify_toc_tracks(0, 1), DT_CD_DATA, "toc data");
    assert_eq(classify_toc_tracks(1, 1), DT_CD_MIXED, "toc mixed");
    assert_eq(classify_toc_tracks(0, 0), DT_UNKNOWN, "toc empty");
    return 0;
}

fn test_toc_operations() {
    var tracks = vec_new();
    vec_push(tracks, toc_entry_new(1, TT_AUDIO, 0, 22050, 18050));
    vec_push(tracks, toc_entry_new(2, TT_AUDIO, 22050, 18000, 24000));
    vec_push(tracks, toc_entry_new(3, TT_DATA, 40050, 100000, 0));
    var toc = disc_toc_new(DT_CD_MIXED, tracks, 700000000);
    assert_eq(toc_audio_track_count(toc), 2, "toc audio cnt");
    assert_eq(toc_data_track_count(toc), 1, "toc data cnt");
    assert_eq(toc_total_audio_duration_x100(toc), 42050, "toc dur");
    assert_eq(toc_disc_type(toc), DT_CD_MIXED, "toc type");
    assert_eq(toc_total_size(toc), 700000000, "toc size");
    return 0;
}

fn test_toc_empty() {
    var toc = disc_toc_new(DT_BLANK, vec_new(), 0);
    assert_eq(toc_audio_track_count(toc), 0, "empty audio");
    assert_eq(toc_data_track_count(toc), 0, "empty data");
    assert_eq(toc_total_audio_duration_x100(toc), 0, "empty dur");
    return 0;
}

fn test_toc_entry_fields() {
    var e = toc_entry_new(5, TT_DATA, 40050, 100000, 0);
    assert_eq(te_number(e), 5, "te num");
    assert_eq(te_track_type(e), TT_DATA, "te type");
    assert_eq(te_start_lba(e), 40050, "te lba");
    assert_eq(te_length_sectors(e), 100000, "te len");
    assert_eq(te_duration_x100(e), 0, "te dur");
    return 0;
}

fn test_tray_state_str() {
    assert(streq(tray_state_to_str(TS_OPEN), "open"), "ts open");
    assert(streq(tray_state_to_str(TS_CLOSED), "closed"), "ts closed");
    assert(streq(tray_state_to_str(TS_UNKNOWN), "unknown"), "ts unk");
    return 0;
}

fn test_ioctl_constants() {
    assert_eq(IOCTL_CDROMEJECT, 0x5309, "ioctl eject");
    assert_eq(IOCTL_CDROMCLOSETRAY, 0x5319, "ioctl close");
    assert_eq(IOCTL_CDROM_DRIVE_STATUS, 0x5326, "ioctl status");
    assert_eq(IOCTL_CDROMREADTOCHDR, 0x5305, "ioctl tochdr");
    assert_eq(IOCTL_CDROMREADTOCENTRY, 0x5306, "ioctl tocentry");
    assert_eq(CDS_NO_DISC, 1, "cds no disc");
    assert_eq(CDS_TRAY_OPEN, 2, "cds tray open");
    assert_eq(CDS_DRIVE_NOT_READY, 3, "cds not ready");
    assert_eq(CDS_DISC_OK, 4, "cds disc ok");
    return 0;
}

