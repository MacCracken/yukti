fn test_error_kind_str_all() {
    assert(streq(yukti_err_kind_str(ERR_DEVICE_NOT_FOUND), "device not found"), "kind 0");
    assert(streq(yukti_err_kind_str(ERR_DEVICE_BUSY), "device busy"), "kind 1");
    assert(streq(yukti_err_kind_str(ERR_MOUNT_FAILED), "mount failed"), "kind 2");
    assert(streq(yukti_err_kind_str(ERR_UNMOUNT_FAILED), "unmount failed"), "kind 3");
    assert(streq(yukti_err_kind_str(ERR_EJECT_FAILED), "eject failed"), "kind 4");
    assert(streq(yukti_err_kind_str(ERR_TRAY_FAILED), "tray operation failed"), "kind 5");
    assert(streq(yukti_err_kind_str(ERR_PERMISSION_DENIED), "permission denied"), "kind 6");
    assert(streq(yukti_err_kind_str(ERR_UDEV), "udev error"), "kind 7");
    assert(streq(yukti_err_kind_str(ERR_ALREADY_MOUNTED), "device already mounted"), "kind 8");
    assert(streq(yukti_err_kind_str(9), "operation timed out"), "kind 9");
    assert(streq(yukti_err_kind_str(ERR_UDEV_SOCKET), "udev socket error"), "kind 10");
    assert(streq(yukti_err_kind_str(ERR_UDEV_PARSE), "udev parse error"), "kind 11");
    assert(streq(yukti_err_kind_str(ERR_NO_MEDIA), "no media in device"), "kind 12");
    assert(streq(yukti_err_kind_str(ERR_UNSUPPORTED_FS), "unsupported filesystem"), "kind 13");
    assert(streq(yukti_err_kind_str(ERR_IO), "io error"), "kind 14");
    assert(streq(yukti_err_kind_str(ERR_PARSE), "parse error"), "kind 15");
    return 0;
}

fn test_error_result() {
    var ok_r = Ok(42);
    assert(is_ok(ok_r), "result ok");
    assert_eq(payload(ok_r), 42, "result payload");
    var err_r = err_device_not_found(str_from("test"));
    assert(is_ok(err_r) == 0, "result err");
    return 0;
}

fn test_error_errno_mapping() {
    var r1 = map_errno_to_err(1, "mount", str_from("/dev/sda"));
    assert(is_ok(r1) == 0, "errno 1 is err");
    var r2 = map_errno_to_err(13, "mount", str_from("/dev/sda"));
    assert(is_ok(r2) == 0, "errno 13 is err");
    var r3 = map_errno_to_err(16, "mount", str_from("/dev/sda"));
    assert(is_ok(r3) == 0, "errno 16 is err");
    var r4 = map_errno_to_err(123, "open", str_from("/dev/sr0"));
    assert(is_ok(r4) == 0, "errno 123 is err");
    var r5 = map_errno_to_err(999, "op", str_from("/dev/x"));
    assert(is_ok(r5) == 0, "errno 999 is err");
    return 0;
}

