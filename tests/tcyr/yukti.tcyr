fn test_device_class_display_all() {
    test_group("device");
    assert(streq(device_class_to_str(DC_USB_STORAGE), "usb-storage"), "class usb");
    assert(streq(device_class_to_str(DC_OPTICAL), "optical"), "class optical");
    assert(streq(device_class_to_str(DC_BLOCK_INTERNAL), "block-internal"), "class block");
    assert(streq(device_class_to_str(DC_SD_CARD), "sd-card"), "class sd");
    assert(streq(device_class_to_str(DC_NETWORK), "network"), "class net");
    assert(streq(device_class_to_str(DC_LOOP), "loop"), "class loop");
    assert(streq(device_class_to_str(DC_DEVICE_MAPPER), "device-mapper"), "class dm");
    assert(streq(device_class_to_str(DC_UNKNOWN), "unknown"), "class unknown");
    return 0;
}

fn test_device_state_display_all() {
    assert(streq(device_state_to_str(DS_READY), "ready"), "state ready");
    assert(streq(device_state_to_str(DS_MOUNTED), "mounted"), "state mounted");
    assert(streq(device_state_to_str(DS_NO_MEDIA), "no-media"), "state nomedia");
    assert(streq(device_state_to_str(DS_EJECTING), "ejecting"), "state ejecting");
    assert(streq(device_state_to_str(DS_DETACHED), "detached"), "state detached");
    assert(streq(device_state_to_str(DS_ERROR), "error"), "state error");
    return 0;
}

fn test_capabilities_bitflags() {
    var caps = CAP_READ | CAP_WRITE | CAP_REMOVABLE;
    assert(has_cap(caps, CAP_READ), "cap read");
    assert(has_cap(caps, CAP_WRITE), "cap write");
    assert(has_cap(caps, CAP_REMOVABLE), "cap removable");
    assert(has_cap(caps, CAP_EJECT) == 0, "cap no eject");
    assert(has_cap(caps, CAP_TRIM) == 0, "cap no trim");
    return 0;
}

fn test_capabilities_empty() {
    assert(has_cap(0, CAP_READ) == 0, "empty no read");
    assert(has_cap(0, CAP_WRITE) == 0, "empty no write");
    return 0;
}

fn test_capabilities_all() {
    var all = CAP_READ | CAP_WRITE | CAP_EJECT | CAP_MEDIA_CHANGE | CAP_REMOVABLE |
    CAP_TRIM | CAP_HOTPLUG | CAP_TRAY_CONTROL | CAP_AUDIO_PLAYBACK | CAP_BURN;
    assert(has_cap(all, CAP_READ), "all read");
    assert(has_cap(all, CAP_BURN), "all burn");
    assert(has_cap(all, CAP_TRIM), "all trim");
    assert(has_cap(all, CAP_AUDIO_PLAYBACK), "all audio");
    return 0;
}

fn test_device_id() {
    var id = device_id_new(str_from("block:sdb1"));
    assert(str_eq_cstr(device_id_str(id), "block:sdb1"), "id str");
    return 0;
}

fn test_device_id_from_cstr() {
    var id = device_id_new_cstr("block:sdb1");
    assert(str_eq_cstr(device_id_str(id), "block:sdb1"), "id from cstr");
    return 0;
}

fn test_device_id_equality() {
    var a = device_id_new_cstr("block:sdb1");
    var b = device_id_new_cstr("block:sdb1");
    var c = device_id_new_cstr("block:sdc1");
    assert(device_id_eq(a, b), "id eq same");
    assert(device_id_eq(a, c) == 0, "id neq diff");
    return 0;
}

fn test_device_info_new() {
    var info = device_info_new(device_id_new_cstr("block:sdb1"), str_from("/dev/sdb1"), DC_USB_STORAGE);
    assert_eq(di_class(info), DC_USB_STORAGE, "info class");
    assert_eq(di_state(info), DS_READY, "info state");
    assert_eq(device_info_is_mounted(info), 0, "info not mounted");
    assert(device_info_is_removable(info), "info removable");
    assert_eq(di_caps(info), 0, "info no caps");
    assert_eq(di_label(info), 0, "info no label");
    assert_eq(di_vendor(info), 0, "info no vendor");
    assert_eq(di_serial(info), 0, "info no serial");
    assert_eq(di_fs_type(info), 0, "info no fstype");
    assert_eq(di_mount_point(info), 0, "info no mp");
    assert_eq(di_size_bytes(info), 0, "info size 0");
    assert_eq(di_part_table(info), 0, "info no pt");
    return 0;
}

fn test_device_info_has_cap() {
    var info = device_info_new(device_id_new_cstr("block:sr0"), str_from("/dev/sr0"), DC_OPTICAL);
    assert(device_info_has_cap(info, CAP_EJECT) == 0, "no cap before");
    di_add_cap(info, CAP_EJECT);
    di_add_cap(info, CAP_TRAY_CONTROL);
    assert(device_info_has_cap(info, CAP_EJECT), "cap eject");
    assert(device_info_has_cap(info, CAP_TRAY_CONTROL), "cap tray");
    assert(device_info_has_cap(info, CAP_BURN) == 0, "no burn");
    return 0;
}

fn test_display_name_priority() {
    var info = device_info_new(device_id_new_cstr("test"), str_from("/dev/sdc1"), DC_USB_STORAGE);
    assert(str_eq_cstr(device_info_display_name(info), "/dev/sdc1"), "name dev_path");
    di_set_model(info, str_from("SanDisk Cruzer"));
    assert(str_eq_cstr(device_info_display_name(info), "SanDisk Cruzer"), "name model");
    di_set_label(info, str_from("MY_USB"));
    assert(str_eq_cstr(device_info_display_name(info), "MY_USB"), "name label");
    return 0;
}

fn test_size_display() {
    var info = device_info_new(device_id_new_cstr("t"), str_from("/dev/sda"), DC_BLOCK_INTERNAL);
    var sb = str_builder_new();
    device_info_size_display(info, sb);
    assert(str_eq_cstr(str_builder_build(sb), "unknown"), "size unknown");

    di_set_size_bytes(info, 512);
    sb = str_builder_new();
    device_info_size_display(info, sb);
    var s = str_builder_build(sb);
    assert(str_contains_cstr(s, "512"), "size 512");
    assert(str_contains_cstr(s, "B"), "size B");

    di_set_size_bytes(info, 1024);
    sb = str_builder_new();
    device_info_size_display(info, sb);
    s = str_builder_build(sb);
    assert(str_contains_cstr(s, "KB"), "size KB");

    di_set_size_bytes(info, 17179869184);
    sb = str_builder_new();
    device_info_size_display(info, sb);
    s = str_builder_build(sb);
    assert(str_contains_cstr(s, "GB"), "size 16GB");
    return 0;
}

fn test_size_display_tb() {
    var info = device_info_new(device_id_new_cstr("t"), str_from("/dev/sda"), DC_BLOCK_INTERNAL);
    di_set_size_bytes(info, 2199023255552);
    var sb = str_builder_new();
    device_info_size_display(info, sb);
    var s = str_builder_build(sb);
    assert(str_contains_cstr(s, "TB"), "size 2TB");
    return 0;
}

fn test_is_mounted() {
    var info = device_info_new(device_id_new_cstr("t"), str_from("/dev/sdb1"), DC_USB_STORAGE);
    assert(device_info_is_mounted(info) == 0, "not mounted");
    di_set_state(info, DS_MOUNTED);
    assert(device_info_is_mounted(info), "mounted by state");
    di_set_state(info, DS_READY);
    di_set_mount_point(info, str_from("/mnt/usb"));
    assert(device_info_is_mounted(info), "mounted by mp");
    return 0;
}

fn test_is_removable() {
    var u = device_info_new(device_id_new_cstr("u"), str_from("/dev/sdb1"), DC_USB_STORAGE);
    var s = device_info_new(device_id_new_cstr("s"), str_from("/dev/mmcblk0"), DC_SD_CARD);
    var o = device_info_new(device_id_new_cstr("o"), str_from("/dev/sr0"), DC_OPTICAL);
    var i = device_info_new(device_id_new_cstr("i"), str_from("/dev/nvme0n1"), DC_BLOCK_INTERNAL);
    assert(device_info_is_removable(u), "usb rem");
    assert(device_info_is_removable(s), "sd rem");
    assert(device_info_is_removable(o), "opt rem");
    assert(device_info_is_removable(i) == 0, "int not rem");
    var hi = device_info_new(device_id_new_cstr("h"), str_from("/dev/sda"), DC_BLOCK_INTERNAL);
    di_add_cap(hi, CAP_REMOVABLE);
    assert(device_info_is_removable(hi), "int+cap rem");
    return 0;
}

fn test_device_info_usb_ids() {
    var info = device_info_new(device_id_new_cstr("t"), str_from("/dev/sdb1"), DC_USB_STORAGE);
    di_set_usb_vid(info, 0x0781);
    di_set_usb_pid(info, 0x5567);
    assert_eq(di_usb_vid(info), 0x0781, "usb vid");
    assert_eq(di_usb_pid(info), 0x5567, "usb pid");
    return 0;
}

fn test_device_info_partition_table() {
    var info = device_info_new(device_id_new_cstr("t"), str_from("/dev/sda"), DC_BLOCK_INTERNAL);
    di_set_part_table(info, str_from("gpt"));
    assert(str_eq_cstr(di_part_table(info), "gpt"), "pt gpt");
    return 0;
}

fn test_device_info_json() {
    var info = device_info_new(device_id_new_cstr("test:dev"), str_from("/dev/sdb"), DC_USB_STORAGE);
    di_set_caps(info, CAP_READ | CAP_WRITE | CAP_EJECT);
    di_set_label(info, str_from("TEST_DRIVE"));
    di_set_vendor(info, str_from("TestVendor"));
    di_set_size_bytes(info, 1048576);
    var sb = str_builder_new();
    device_info_to_json(info, sb);
    var json = str_builder_build(sb);
    assert(str_contains_cstr(json, "test:dev"), "json id");
    assert(str_contains_cstr(json, "usb-storage"), "json class");
    assert(str_contains_cstr(json, "TEST_DRIVE"), "json label");
    assert(str_contains_cstr(json, "TestVendor"), "json vendor");
    return 0;
}

fn test_query_permissions_dev_null() {
    var perms = query_permissions("/dev/null");
    assert(perms != 0, "perms not null");
    assert_eq(perms_uid(perms), 0, "perms uid 0");
    return 0;
}

fn test_query_permissions_nonexistent() {
    var perms = query_permissions("/dev/yukti_nonexistent_xyz");
    assert_eq(perms, 0, "perms nonexistent");
    return 0;
}

fn test_query_health_nonexistent() {
    var h = query_device_health(str_from("nonexistent_yukti_test_device"));
    assert_eq(dh_rotational(h), 0 - 1, "health rot unknown");
    assert_eq(dh_scheduler(h), 0, "health no sched");
    return 0;
}

# ===================================================================
# Event tests (12 in Rust)
# ===================================================================

fn make_test_event(kind) {
    return device_event_new(device_id_new_cstr("block:sdb1"), DC_USB_STORAGE, kind, str_from("/dev/sdb1"));
}

fn test_event_attach() {
    test_group("event");
    var e = make_test_event(EK_ATTACHED);
    assert(device_event_is_attach(e), "is attach");
    assert(device_event_is_detach(e) == 0, "not detach");
    assert(device_event_is_removable(e), "removable");
    return 0;
}

fn test_event_detach() {
    var e = make_test_event(EK_DETACHED);
    assert(device_event_is_detach(e), "is detach");
    assert(device_event_is_attach(e) == 0, "not attach");
    return 0;
}

fn test_event_display_all() {
    assert(streq(event_kind_to_str(EK_ATTACHED), "attached"), "ek attached");
    assert(streq(event_kind_to_str(EK_DETACHED), "detached"), "ek detached");
    assert(streq(event_kind_to_str(EK_MEDIA_CHANGED), "media-changed"), "ek media");
    assert(streq(event_kind_to_str(EK_MOUNTED), "mounted"), "ek mounted");
    assert(streq(event_kind_to_str(EK_UNMOUNTED), "unmounted"), "ek unmounted");
    assert(streq(event_kind_to_str(EK_ERROR), "error"), "ek error");
    return 0;
}

fn test_event_with_info() {
    var e = make_test_event(EK_ATTACHED);
    var info = device_info_new(device_id_new_cstr("block:sdb1"), str_from("/dev/sdb1"), DC_USB_STORAGE);
    device_event_with_info(e, info);
    assert(de_device_info(e) != 0, "has info");
    return 0;
}

fn test_non_removable_event() {
    var id = device_id_new_cstr("block:nvme0n1");
    var e = device_event_new(id, DC_BLOCK_INTERNAL, EK_ATTACHED, str_from("/dev/nvme0n1"));
    assert(device_event_is_removable(e) == 0, "int not rem");
    return 0;
}

fn test_event_collector() {
    var c = event_collector_new();
    assert_eq(event_collector_count(c), 0, "empty");
    event_collector_push(c, make_test_event(EK_ATTACHED));
    event_collector_push(c, make_test_event(EK_DETACHED));
    assert_eq(event_collector_count(c), 2, "count 2");
    assert(device_event_is_attach(event_collector_get(c, 0)), "[0] attach");
    assert(device_event_is_detach(event_collector_get(c, 1)), "[1] detach");
    event_collector_clear(c);
    assert_eq(event_collector_count(c), 0, "cleared");
    return 0;
}

fn test_event_collector_bulk() {
    var c = event_collector_new();
    for (var i = 0; i < 100; i = i + 1) {
        event_collector_push(c, make_test_event(EK_ATTACHED));
    }
    assert_eq(event_collector_count(c), 100, "bulk 100");
    return 0;
}

fn test_event_kind_display() {
    var e = make_test_event(EK_MOUNTED);
    de_set_extra(e, str_from("/mnt/usb"));
    var sb = str_builder_new();
    device_event_kind_display(e, sb);
    var s = str_builder_build(sb);
    assert(str_contains_cstr(s, "mounted"), "mounted display");
    assert(str_contains_cstr(s, "/mnt/usb"), "mounted mp display");
    return 0;
}

fn test_event_error_display() {
    var e = make_test_event(EK_ERROR);
    de_set_extra(e, str_from("IO fault"));
    var sb = str_builder_new();
    device_event_kind_display(e, sb);
    var s = str_builder_build(sb);
    assert(str_contains_cstr(s, "error"), "error display");
    assert(str_contains_cstr(s, "IO fault"), "error msg display");
    return 0;
}

# ===================================================================
# Storage tests (63 in Rust — skip mount/unmount/eject needing root)
# ===================================================================

fn test_filesystem_parse() {
    test_group("storage");
    assert_eq(filesystem_from_str("ext4"), FS_EXT4, "fs ext4");
    assert_eq(filesystem_from_str("btrfs"), FS_BTRFS, "fs btrfs");
    assert_eq(filesystem_from_str("xfs"), FS_XFS, "fs xfs");
    assert_eq(filesystem_from_str("vfat"), FS_VFAT, "fs vfat");
    assert_eq(filesystem_from_str("fat32"), FS_VFAT, "fs fat32");
    assert_eq(filesystem_from_str("fat16"), FS_VFAT, "fs fat16");
    assert_eq(filesystem_from_str("ntfs"), FS_NTFS, "fs ntfs");
    assert_eq(filesystem_from_str("exfat"), FS_EXFAT, "fs exfat");
    assert_eq(filesystem_from_str("iso9660"), FS_ISO9660, "fs iso9660");
    assert_eq(filesystem_from_str("udf"), FS_UDF, "fs udf");
    assert_eq(filesystem_from_str("hfsplus"), FS_HFSPLUS, "fs hfsplus");
    assert_eq(filesystem_from_str("hfs+"), FS_HFSPLUS, "fs hfs+");
    assert_eq(filesystem_from_str("swap"), FS_SWAP, "fs swap");
    assert_eq(filesystem_from_str("crypto_luks"), FS_LUKS, "fs crypto_luks");
    assert_eq(filesystem_from_str("luks"), FS_LUKS, "fs luks");
    assert_eq(filesystem_from_str("f2fs"), FS_F2FS, "fs f2fs");
    assert_eq(filesystem_from_str("erofs"), FS_EROFS, "fs erofs");
    assert_eq(filesystem_from_str("tmpfs"), FS_TMPFS, "fs tmpfs");
    assert_eq(filesystem_from_str("cifs"), FS_CIFS, "fs cifs");
    assert_eq(filesystem_from_str("nfs"), FS_NFS, "fs nfs");
    assert_eq(filesystem_from_str("nfs4"), FS_NFS, "fs nfs4");
    assert_eq(filesystem_from_str("zfs"), FS_UNKNOWN, "fs unknown");
    return 0;
}

