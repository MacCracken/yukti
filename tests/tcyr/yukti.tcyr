    str_from("/dev/sda"), str_from("block"), str_from("disk"), props);
    var caps = extract_capabilities(e, DC_BLOCK_INTERNAL);
    assert(has_cap(caps, CAP_TRIM), "trim cap");
    return 0;
}

# ===================================================================
# Udev rules tests (13 in Rust)
# ===================================================================

fn make_test_rule() {
    var matches = vec_new();
    vec_push(matches, pair_new(str_from("SUBSYSTEM"), str_from("usb")));
    vec_push(matches, pair_new(str_from("ATTR{idVendor}"), str_from("1234")));
    var actions = vec_new();
    vec_push(actions, pair_new(str_from("MODE"), str_from("0666")));
    return udev_rule_new(str_from("99-yukti-test"), matches, actions);
}

fn test_render_rule() {
    test_group("udev_rules");
    var rendered = render_rule(make_test_rule());
    assert(str_contains_cstr(rendered, "SUBSYSTEM"), "render subsys");
    assert(str_contains_cstr(rendered, "usb"), "render usb");
    assert(str_contains_cstr(rendered, "MODE"), "render mode");
    assert(str_contains_cstr(rendered, "0666"), "render 0666");
    assert(str_contains_cstr(rendered, "==\""), "render match op");
    assert(str_contains_cstr(rendered, "=\""), "render action op");
    return 0;
}

fn test_validate_rule_good() {
    assert(is_ok(validate_rule(make_test_rule())), "valid rule");
    return 0;
}

fn test_validate_rule_empty_name() {
    var r = make_test_rule();
    var bad = udev_rule_new(str_from(""), ur_match_attrs(r), ur_actions(r));
    assert(is_ok(validate_rule(bad)) == 0, "empty name");
    return 0;
}

fn test_validate_rule_no_matches() {
    var r = make_test_rule();
    var bad = udev_rule_new(str_from("test"), vec_new(), ur_actions(r));
    assert(is_ok(validate_rule(bad)) == 0, "no matches");
    return 0;
}

fn test_validate_rule_no_actions() {
    var r = make_test_rule();
    var bad = udev_rule_new(str_from("test"), ur_match_attrs(r), vec_new());
    assert(is_ok(validate_rule(bad)) == 0, "no actions");
    return 0;
}

fn test_rule_accessors() {
    var r = make_test_rule();
    assert(str_eq_cstr(ur_name(r), "99-yukti-test"), "rule name");
    assert_eq(vec_len(ur_match_attrs(r)), 2, "rule 2 matches");
    assert_eq(vec_len(ur_actions(r)), 1, "rule 1 action");
    var m0 = vec_get(ur_match_attrs(r), 0);
    assert(str_eq_cstr(pair_key(m0), "SUBSYSTEM"), "pair key");
    assert(str_eq_cstr(pair_value(m0), "usb"), "pair val");
    return 0;
}

