    test_error_to_str();
    test_error_result();

    # Device tests
    test_device_class();
    test_device_state();
    test_capabilities();
    test_device_id();
    test_device_info_new();
    test_device_info_has_cap();
    test_device_info_display_name();
    test_device_info_is_mounted();
    test_device_info_is_removable();
    test_device_info_size_display();

    # Event tests
    test_event_kind();
    test_event_predicates();
    test_event_with_info();
    test_event_collector();

    # Storage tests
    test_filesystem_parse();
    test_filesystem_parse_ci();
    test_filesystem_writable();
    test_filesystem_optical();
    test_filesystem_display();
    test_validate_mount_point();
    test_unescape_mount_path();
    test_find_mount_in();

    # Optical tests
    test_disc_type();
    test_disc_type_display();
    test_detect_disc_type();
    test_detect_case_insensitive();
    test_classify_toc_tracks();
    test_toc_operations();

    # Udev tests
    test_classify_device();
    test_extract_capabilities();
    test_device_info_from_udev();
    test_udev_event_predicates();

    # Udev rules tests
    test_render_rule();
    test_validate_rule();

    # Linux device manager tests
    test_linux_dm();

    var r = assert_summary();
    syscall(60, r);
}

main();
