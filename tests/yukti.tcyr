# yukti test suite
# Tests all modules: error, device, event, storage, optical, udev, udev_rules

include "src/lib.cyr"
include "lib/assert.cyr"

# ===================================================================
# Error tests
# ===================================================================

fn test_error_kind() {
    test_group("error");

    var e = yukti_err_new(ERR_DEVICE_NOT_FOUND, str_from("usb-001"));
    assert_eq(yukti_err_kind(e), ERR_DEVICE_NOT_FOUND, "err kind");
    assert(str_eq_cstr(yukti_err_detail(e), "usb-001"), "err detail");
    assert_eq(yukti_err_context(e), 0, "err no context");

    var e2 = yukti_err_new_ctx(ERR_MOUNT_FAILED, str_from("bad superblock"), str_from("/dev/sdb1"));
    assert_eq(yukti_err_kind(e2), ERR_MOUNT_FAILED, "err ctx kind");
    assert(str_eq_cstr(yukti_err_detail(e2), "bad superblock"), "err ctx detail");
    assert(str_eq_cstr(yukti_err_context(e2), "/dev/sdb1"), "err ctx context");

    return 0;
}

fn test_error_kind_str() {
    assert(streq(yukti_err_kind_str(ERR_DEVICE_NOT_FOUND), "device not found"), "kind str 0");
    assert(streq(yukti_err_kind_str(ERR_DEVICE_BUSY), "device busy"), "kind str 1");
    assert(streq(yukti_err_kind_str(ERR_MOUNT_FAILED), "mount failed"), "kind str 2");
    assert(streq(yukti_err_kind_str(ERR_IO), "io error"), "kind str io");
    assert(streq(yukti_err_kind_str(ERR_PARSE), "parse error"), "kind str parse");
    return 0;
}

fn test_error_to_str() {
    var e = yukti_err_new_ctx(ERR_PERMISSION_DENIED, str_from("mount"), str_from("/dev/sda"));
    var sb = str_builder_new();
    yukti_err_to_str(e, sb);
    var s = str_builder_build(sb);
    assert(str_contains_cstr(s, "permission denied"), "err to_str kind");
    assert(str_contains_cstr(s, "mount"), "err to_str detail");
    assert(str_contains_cstr(s, "/dev/sda"), "err to_str context");
    return 0;
}

fn test_error_result() {
    var ok_r = Ok(42);
    assert(is_ok(ok_r), "result ok");
    assert_eq(payload(ok_r), 42, "result payload");

    var err_r = err_device_not_found(str_from("test"));
    assert(is_ok(err_r) == 0, "result err");
    return 0;
}

# ===================================================================
# Device tests
# ===================================================================

fn test_device_class() {
    test_group("device");

    assert(streq(device_class_to_str(DC_USB_STORAGE), "usb-storage"), "class usb");
    assert(streq(device_class_to_str(DC_OPTICAL), "optical"), "class optical");
    assert(streq(device_class_to_str(DC_BLOCK_INTERNAL), "block-internal"), "class block");
    assert(streq(device_class_to_str(DC_SD_CARD), "sd-card"), "class sd");
    assert(streq(device_class_to_str(DC_NETWORK), "network"), "class net");
    assert(streq(device_class_to_str(DC_LOOP), "loop"), "class loop");
    assert(streq(device_class_to_str(DC_DEVICE_MAPPER), "device-mapper"), "class dm");
    assert(streq(device_class_to_str(DC_UNKNOWN), "unknown"), "class unknown");
    return 0;
}

fn test_device_state() {
    assert(streq(device_state_to_str(DS_READY), "ready"), "state ready");
    assert(streq(device_state_to_str(DS_MOUNTED), "mounted"), "state mounted");
    assert(streq(device_state_to_str(DS_NO_MEDIA), "no-media"), "state nomedia");
    assert(streq(device_state_to_str(DS_EJECTING), "ejecting"), "state ejecting");
    assert(streq(device_state_to_str(DS_DETACHED), "detached"), "state detached");
    assert(streq(device_state_to_str(DS_ERROR), "error"), "state error");
    return 0;
}

fn test_capabilities() {
    var caps = CAP_READ | CAP_WRITE | CAP_REMOVABLE;
    assert(has_cap(caps, CAP_READ), "cap read");
    assert(has_cap(caps, CAP_WRITE), "cap write");
    assert(has_cap(caps, CAP_REMOVABLE), "cap removable");
    assert(has_cap(caps, CAP_EJECT) == 0, "cap no eject");
    assert(has_cap(caps, CAP_TRIM) == 0, "cap no trim");
    assert(has_cap(0, CAP_READ) == 0, "cap empty");
    return 0;
}

fn test_device_id() {
    var id = device_id_new(str_from("block:sdb1"));
    assert(str_eq_cstr(device_id_str(id), "block:sdb1"), "id str");

    var id2 = device_id_new_cstr("block:sdb1");
    assert(device_id_eq(id, id2), "id eq");

    var id3 = device_id_new_cstr("block:sdc1");
    assert(device_id_eq(id, id3) == 0, "id neq");
    return 0;
}

fn test_device_info_new() {
    var id = device_id_new_cstr("block:sdb1");
    var info = device_info_new(id, str_from("/dev/sdb1"), DC_USB_STORAGE);

    assert_eq(di_class(info), DC_USB_STORAGE, "info class");
    assert_eq(di_state(info), DS_READY, "info state");
    assert_eq(device_info_is_mounted(info), 0, "info not mounted");
    assert(device_info_is_removable(info), "info removable");
    assert_eq(di_caps(info), 0, "info no caps");
    assert_eq(di_label(info), 0, "info no label");
    assert_eq(di_vendor(info), 0, "info no vendor");
    return 0;
}

fn test_device_info_has_cap() {
    var id = device_id_new_cstr("block:sr0");
    var info = device_info_new(id, str_from("/dev/sr0"), DC_OPTICAL);

    assert(device_info_has_cap(info, CAP_EJECT) == 0, "no cap before add");
    di_add_cap(info, CAP_EJECT);
    di_add_cap(info, CAP_TRAY_CONTROL);
    assert(device_info_has_cap(info, CAP_EJECT), "cap eject after add");
    assert(device_info_has_cap(info, CAP_TRAY_CONTROL), "cap tray after add");
    assert(device_info_has_cap(info, CAP_BURN) == 0, "no burn");
    return 0;
}

fn test_device_info_display_name() {
    var id = device_id_new_cstr("test");
    var info = device_info_new(id, str_from("/dev/sdc1"), DC_USB_STORAGE);

    # No label, no model -> dev_path
    var name = device_info_display_name(info);
    assert(str_eq_cstr(name, "/dev/sdc1"), "display dev_path");

    # Set model
    di_set_model(info, str_from("SanDisk Cruzer"));
    name = device_info_display_name(info);
    assert(str_eq_cstr(name, "SanDisk Cruzer"), "display model");

    # Set label (takes priority)
    di_set_label(info, str_from("MY_USB"));
    name = device_info_display_name(info);
    assert(str_eq_cstr(name, "MY_USB"), "display label");
    return 0;
}

fn test_device_info_is_mounted() {
    var id = device_id_new_cstr("test");
    var info = device_info_new(id, str_from("/dev/sdb1"), DC_USB_STORAGE);
    assert(device_info_is_mounted(info) == 0, "not mounted");

    di_set_state(info, DS_MOUNTED);
    assert(device_info_is_mounted(info), "mounted by state");

    di_set_state(info, DS_READY);
    di_set_mount_point(info, str_from("/mnt/usb"));
    assert(device_info_is_mounted(info), "mounted by mp");
    return 0;
}

fn test_device_info_is_removable() {
    var usb = device_info_new(device_id_new_cstr("usb"), str_from("/dev/sdb1"), DC_USB_STORAGE);
    assert(device_info_is_removable(usb), "usb removable");

    var sd = device_info_new(device_id_new_cstr("sd"), str_from("/dev/mmcblk0"), DC_SD_CARD);
    assert(device_info_is_removable(sd), "sd removable");

    var internal = device_info_new(device_id_new_cstr("ssd"), str_from("/dev/nvme0n1"), DC_BLOCK_INTERNAL);
    assert(device_info_is_removable(internal) == 0, "internal not removable");

    # BlockInternal with REMOVABLE cap
    di_add_cap(internal, CAP_REMOVABLE);
    assert(device_info_is_removable(internal), "internal with cap removable");
    return 0;
}

fn test_device_info_size_display() {
    var id = device_id_new_cstr("test");
    var info = device_info_new(id, str_from("/dev/sda"), DC_BLOCK_INTERNAL);

    var sb = str_builder_new();
    device_info_size_display(info, sb);
    var s = str_builder_build(sb);
    assert(str_eq_cstr(s, "unknown"), "size unknown");

    di_set_size_bytes(info, 512);
    sb = str_builder_new();
    device_info_size_display(info, sb);
    s = str_builder_build(sb);
    assert(str_contains_cstr(s, "512"), "size 512");
    assert(str_contains_cstr(s, "B"), "size B");

    di_set_size_bytes(info, 1024);
    sb = str_builder_new();
    device_info_size_display(info, sb);
    s = str_builder_build(sb);
    assert(str_contains_cstr(s, "1"), "size 1KB");
    assert(str_contains_cstr(s, "KB"), "size KB unit");
    return 0;
}

# ===================================================================
# Event tests
# ===================================================================

fn test_event_kind() {
    test_group("event");

    assert(streq(event_kind_to_str(EK_ATTACHED), "attached"), "ek attached");
    assert(streq(event_kind_to_str(EK_DETACHED), "detached"), "ek detached");
    assert(streq(event_kind_to_str(EK_MEDIA_CHANGED), "media-changed"), "ek media");
    assert(streq(event_kind_to_str(EK_UNMOUNTED), "unmounted"), "ek unmounted");
    return 0;
}

fn make_test_event(kind) {
    return device_event_new(
        device_id_new_cstr("block:sdb1"),
        DC_USB_STORAGE,
        kind,
        str_from("/dev/sdb1")
    );
}

fn test_event_predicates() {
    var e = make_test_event(EK_ATTACHED);
    assert(device_event_is_attach(e), "event is attach");
    assert(device_event_is_detach(e) == 0, "event not detach");
    assert(device_event_is_removable(e), "event removable");

    var e2 = make_test_event(EK_DETACHED);
    assert(device_event_is_detach(e2), "event is detach");
    assert(device_event_is_attach(e2) == 0, "event not attach");

    var e3 = device_event_new(
        device_id_new_cstr("block:nvme0n1"),
        DC_BLOCK_INTERNAL,
        EK_ATTACHED,
        str_from("/dev/nvme0n1")
    );
    assert(device_event_is_removable(e3) == 0, "internal not removable");
    return 0;
}

fn test_event_with_info() {
    var e = make_test_event(EK_ATTACHED);
    var info = device_info_new(device_id_new_cstr("block:sdb1"),
                                str_from("/dev/sdb1"), DC_USB_STORAGE);
    device_event_with_info(e, info);
    assert(de_device_info(e) != 0, "event has info");
    return 0;
}

fn test_event_collector() {
    var c = event_collector_new();
    assert_eq(event_collector_count(c), 0, "collector empty");

    event_collector_push(c, make_test_event(EK_ATTACHED));
    event_collector_push(c, make_test_event(EK_DETACHED));
    assert_eq(event_collector_count(c), 2, "collector count 2");

    var e0 = event_collector_get(c, 0);
    assert(device_event_is_attach(e0), "collector[0] attach");

    var e1 = event_collector_get(c, 1);
    assert(device_event_is_detach(e1), "collector[1] detach");

    event_collector_clear(c);
    assert_eq(event_collector_count(c), 0, "collector cleared");
    return 0;
}

# ===================================================================
# Storage tests
# ===================================================================

fn test_filesystem_parse() {
    test_group("storage");

    assert_eq(filesystem_from_str("ext4"), FS_EXT4, "fs ext4");
    assert_eq(filesystem_from_str("VFAT"), FS_VFAT, "fs VFAT");
    assert_eq(filesystem_from_str("fat32"), FS_VFAT, "fs fat32");
    assert_eq(filesystem_from_str("iso9660"), FS_ISO9660, "fs iso9660");
    assert_eq(filesystem_from_str("crypto_luks"), FS_LUKS, "fs luks");
    assert_eq(filesystem_from_str("zfs"), FS_UNKNOWN, "fs unknown");
    return 0;
}

fn test_filesystem_parse_ci() {
    assert_eq(filesystem_from_str("EXT4"), FS_EXT4, "fs ci EXT4");
    assert_eq(filesystem_from_str("Ext4"), FS_EXT4, "fs ci Ext4");
    assert_eq(filesystem_from_str("NTFS"), FS_NTFS, "fs ci NTFS");
    assert_eq(filesystem_from_str("Btrfs"), FS_BTRFS, "fs ci Btrfs");
    assert_eq(filesystem_from_str("XFS"), FS_XFS, "fs ci XFS");
    assert_eq(filesystem_from_str("ISO9660"), FS_ISO9660, "fs ci ISO9660");
    assert_eq(filesystem_from_str("UDF"), FS_UDF, "fs ci UDF");
    return 0;
}

fn test_filesystem_writable() {
    assert(filesystem_is_writable(FS_EXT4), "ext4 writable");
    assert(filesystem_is_writable(FS_BTRFS), "btrfs writable");
    assert(filesystem_is_writable(FS_XFS), "xfs writable");
    assert(filesystem_is_writable(FS_VFAT), "vfat writable");
    assert(filesystem_is_writable(FS_NTFS), "ntfs writable");
    assert(filesystem_is_writable(FS_EXFAT), "exfat writable");
    assert(filesystem_is_writable(FS_ISO9660) == 0, "iso not writable");
    assert(filesystem_is_writable(FS_UDF) == 0, "udf not writable");
    assert(filesystem_is_writable(FS_SWAP) == 0, "swap not writable");
    assert(filesystem_is_writable(FS_LUKS) == 0, "luks not writable");
    return 0;
}

fn test_filesystem_optical() {
    assert(filesystem_is_optical(FS_ISO9660), "iso optical");
    assert(filesystem_is_optical(FS_UDF), "udf optical");
    assert(filesystem_is_optical(FS_EXT4) == 0, "ext4 not optical");
    assert(filesystem_is_optical(FS_VFAT) == 0, "vfat not optical");
    return 0;
}

fn test_filesystem_display() {
    assert(streq(filesystem_to_str(FS_EXT4), "ext4"), "fs str ext4");
    assert(streq(filesystem_to_str(FS_BTRFS), "btrfs"), "fs str btrfs");
    assert(streq(filesystem_to_str(FS_VFAT), "vfat"), "fs str vfat");
    assert(streq(filesystem_to_str(FS_HFSPLUS), "hfs+"), "fs str hfs+");
    assert(streq(filesystem_to_str(FS_LUKS), "luks"), "fs str luks");
    return 0;
}

fn test_validate_mount_point() {
    var r1 = validate_mount_point("/mnt/usb");
    assert(is_ok(r1), "valid mount point");

    var r2 = validate_mount_point("relative/path");
    assert(is_ok(r2) == 0, "relative rejected");

    var r3 = validate_mount_point("/");
    assert(is_ok(r3) == 0, "root rejected");

    var r4 = validate_mount_point("/sys");
    assert(is_ok(r4) == 0, "/sys rejected");

    var r5 = validate_mount_point("/dev");
    assert(is_ok(r5) == 0, "/dev rejected");
    return 0;
}

fn test_unescape_mount_path() {
    # Normal path
    var r1 = unescape_mount_path("/mnt/usb", 8);
    assert(str_eq_cstr(r1, "/mnt/usb"), "unescape normal");

    # Octal space: \040
    var escaped = "/mnt/my\\040drive";
    var r2 = unescape_mount_path(escaped, strlen(escaped));
    assert(str_eq_cstr(r2, "/mnt/my drive"), "unescape space");
    return 0;
}

fn test_find_mount_in() {
    var table = "/dev/sda1 / ext4 rw 0 0\n/dev/sdb1 /mnt/usb vfat rw 0 0\n";
    var table_s = str_from(table);

    var r1 = find_mount_in("/dev/sdb1", table_s);
    assert(r1 != 0, "found sdb1");
    assert(str_eq_cstr(r1, "/mnt/usb"), "sdb1 at /mnt/usb");

    var r2 = find_mount_in("/dev/sdc1", table_s);
    assert_eq(r2, 0, "sdc1 not found");
    return 0;
}

# ===================================================================
# Optical tests
# ===================================================================

fn test_disc_type() {
    test_group("optical");

    assert(disc_type_has_audio(DT_CD_AUDIO), "cd audio has audio");
    assert(disc_type_has_audio(DT_CD_MIXED), "cd mixed has audio");
    assert(disc_type_has_audio(DT_DVD_ROM) == 0, "dvd no audio");
    assert(disc_type_has_audio(DT_CD_DATA) == 0, "cd data no audio");

    assert(disc_type_has_data(DT_CD_DATA), "cd data has data");
    assert(disc_type_has_data(DT_CD_MIXED), "cd mixed has data");
    assert(disc_type_has_data(DT_DVD_ROM), "dvd has data");
    assert(disc_type_has_data(DT_CD_AUDIO) == 0, "cd audio no data");
    assert(disc_type_has_data(DT_BLANK) == 0, "blank no data");

    assert(disc_type_is_writable(DT_DVD_WRITABLE), "dvd-rw writable");
    assert(disc_type_is_writable(DT_BLANK), "blank writable");
    assert(disc_type_is_writable(DT_CD_DATA) == 0, "cd data not writable");
    return 0;
}

fn test_disc_type_display() {
    assert(streq(disc_type_to_str(DT_CD_AUDIO), "CD-DA (Audio)"), "dt str audio");
    assert(streq(disc_type_to_str(DT_CD_DATA), "CD-ROM (Data)"), "dt str data");
    assert(streq(disc_type_to_str(DT_DVD_ROM), "DVD-ROM"), "dt str dvd");
    assert(streq(disc_type_to_str(DT_BLURAY), "Blu-ray"), "dt str bluray");
    assert(streq(disc_type_to_str(DT_BLANK), "Blank"), "dt str blank");
    return 0;
}

fn test_detect_disc_type() {
    assert_eq(detect_disc_type("cd", 1, 0), DT_CD_AUDIO, "detect cd audio");
    assert_eq(detect_disc_type("cd-rom", 0, 1), DT_CD_DATA, "detect cd data");
    assert_eq(detect_disc_type("cd", 1, 1), DT_CD_MIXED, "detect cd mixed");
    assert_eq(detect_disc_type("dvd-rom", 0, 1), DT_DVD_ROM, "detect dvd");
    assert_eq(detect_disc_type("dvd-r", 0, 1), DT_DVD_WRITABLE, "detect dvd-r");
    assert_eq(detect_disc_type("dvd-rw", 0, 1), DT_DVD_WRITABLE, "detect dvd-rw");
    assert_eq(detect_disc_type("dvd+r", 0, 1), DT_DVD_WRITABLE, "detect dvd+r");
    assert_eq(detect_disc_type("dvd+rw", 0, 1), DT_DVD_WRITABLE, "detect dvd+rw");
    assert_eq(detect_disc_type("dvd-video", 0, 1), DT_DVD_VIDEO, "detect dvd video");
    assert_eq(detect_disc_type("bd", 0, 1), DT_BLURAY, "detect bd");
    assert_eq(detect_disc_type("blu-ray", 0, 1), DT_BLURAY, "detect blu-ray");
    assert_eq(detect_disc_type("bd-rom", 0, 1), DT_BLURAY, "detect bd-rom");
    assert_eq(detect_disc_type("bd-video", 0, 1), DT_BLURAY_VIDEO, "detect bd-video");
    assert_eq(detect_disc_type("blank", 0, 0), DT_BLANK, "detect blank");
    assert_eq(detect_disc_type("no_disc", 0, 0), DT_BLANK, "detect no_disc");
    assert_eq(detect_disc_type("floppy", 0, 0), DT_UNKNOWN, "detect unknown");
    return 0;
}

fn test_detect_case_insensitive() {
    assert_eq(detect_disc_type("CD", 1, 0), DT_CD_AUDIO, "detect CI CD");
    assert_eq(detect_disc_type("DVD-ROM", 0, 1), DT_DVD_ROM, "detect CI DVD-ROM");
    assert_eq(detect_disc_type("BD", 0, 1), DT_BLURAY, "detect CI BD");
    assert_eq(detect_disc_type("BLANK", 0, 0), DT_BLANK, "detect CI BLANK");
    return 0;
}

fn test_classify_toc_tracks() {
    assert_eq(classify_toc_tracks(1, 0), DT_CD_AUDIO, "toc audio");
    assert_eq(classify_toc_tracks(0, 1), DT_CD_DATA, "toc data");
    assert_eq(classify_toc_tracks(1, 1), DT_CD_MIXED, "toc mixed");
    assert_eq(classify_toc_tracks(0, 0), DT_UNKNOWN, "toc empty");
    return 0;
}

fn test_toc_operations() {
    var tracks = vec_new();
    vec_push(tracks, toc_entry_new(1, TT_AUDIO, 0, 22050, 18050));
    vec_push(tracks, toc_entry_new(2, TT_AUDIO, 22050, 18000, 24000));
    vec_push(tracks, toc_entry_new(3, TT_DATA, 40050, 100000, 0));

    var toc = disc_toc_new(DT_CD_MIXED, tracks, 700000000);
    assert_eq(toc_audio_track_count(toc), 2, "toc audio count");
    assert_eq(toc_data_track_count(toc), 1, "toc data count");
    assert_eq(toc_total_audio_duration_x100(toc), 42050, "toc audio duration");

    # Empty TOC
    var empty_toc = disc_toc_new(DT_BLANK, vec_new(), 0);
    assert_eq(toc_audio_track_count(empty_toc), 0, "empty audio count");
    assert_eq(toc_data_track_count(empty_toc), 0, "empty data count");
    assert_eq(toc_total_audio_duration_x100(empty_toc), 0, "empty duration");
    return 0;
}

# ===================================================================
# Udev tests
# ===================================================================

fn make_usb_udev_event() {
    var props = map_new();
    map_set(props, "ID_BUS", str_from("usb"));
    map_set(props, "ID_VENDOR", str_from("SanDisk"));
    map_set(props, "ID_MODEL", str_from("Cruzer_Blade"));
    map_set(props, "ID_SERIAL_SHORT", str_from("ABC123"));
    map_set(props, "ID_FS_TYPE", str_from("vfat"));
    map_set(props, "ID_FS_LABEL", str_from("MYUSB"));
    map_set(props, "ID_USB_DRIVER", str_from("usb-storage"));

    return udev_event_new(
        str_from("add"),
        str_from("/sys/devices/pci0000:00/usb1/1-1/block/sdb/sdb1"),
        str_from("/dev/sdb1"),
        str_from("block"),
        str_from("partition"),
        props
    );
}

fn make_optical_udev_event() {
    var props = map_new();
    map_set(props, "ID_CDROM", str_from("1"));
    map_set(props, "ID_CDROM_DVD", str_from("1"));
    map_set(props, "ID_CDROM_DVD_RW", str_from("1"));
    map_set(props, "ID_FS_TYPE", str_from("iso9660"));
    map_set(props, "ID_FS_LABEL", str_from("MOVIE_DISC"));

    return udev_event_new(
        str_from("change"),
        str_from("/sys/devices/pci0000:00/ata1/host0/block/sr0"),
        str_from("/dev/sr0"),
        str_from("block"),
        str_from("disk"),
        props
    );
}

fn test_classify_device() {
    test_group("udev");

    var usb = make_usb_udev_event();
    assert_eq(classify_device(usb), DC_USB_STORAGE, "classify usb");

    var opt = make_optical_udev_event();
    assert_eq(classify_device(opt), DC_OPTICAL, "classify optical");
    return 0;
}

fn test_extract_capabilities() {
    var usb = make_usb_udev_event();
    var caps = extract_capabilities(usb, DC_USB_STORAGE);
    assert(has_cap(caps, CAP_READ), "usb cap read");
    assert(has_cap(caps, CAP_WRITE), "usb cap write");
    assert(has_cap(caps, CAP_REMOVABLE), "usb cap removable");
    assert(has_cap(caps, CAP_HOTPLUG), "usb cap hotplug");
    assert(has_cap(caps, CAP_EJECT), "usb cap eject");

    var opt = make_optical_udev_event();
    var opt_caps = extract_capabilities(opt, DC_OPTICAL);
    assert(has_cap(opt_caps, CAP_MEDIA_CHANGE), "opt cap media change");
    assert(has_cap(opt_caps, CAP_TRAY_CONTROL), "opt cap tray");
    assert(has_cap(opt_caps, CAP_BURN), "opt cap burn (dvd-rw)");
    return 0;
}

fn test_device_info_from_udev() {
    var usb = make_usb_udev_event();
    var r = device_info_from_udev(usb);
    assert(is_ok(r), "info from udev ok");

    var info = payload(r);
    assert_eq(di_class(info), DC_USB_STORAGE, "udev info class");
    assert(str_eq_cstr(di_vendor(info), "SanDisk"), "udev info vendor");
    assert(str_eq_cstr(di_model(info), "Cruzer_Blade"), "udev info model");
    assert(str_eq_cstr(di_serial(info), "ABC123"), "udev info serial");
    assert(str_eq_cstr(di_label(info), "MYUSB"), "udev info label");
    assert(str_eq_cstr(di_fs_type(info), "vfat"), "udev info fstype");
    return 0;
}

fn test_udev_event_predicates() {
    var add = udev_event_new(str_from("add"), str_from("/sys/x"), str_from("/dev/x"),
                              str_from("block"), 0, map_new());
    assert(udev_event_is_add(add), "ue is add");
    assert(udev_event_is_remove(add) == 0, "ue not remove");

    var rem = udev_event_new(str_from("remove"), str_from("/sys/x"), str_from("/dev/x"),
                              str_from("block"), 0, map_new());
    assert(udev_event_is_remove(rem), "ue is remove");
    return 0;
}

# ===================================================================
# Udev rules tests
# ===================================================================

fn make_test_rule() {
    var matches = vec_new();
    vec_push(matches, pair_new(str_from("SUBSYSTEM"), str_from("usb")));
    vec_push(matches, pair_new(str_from("ATTR{idVendor}"), str_from("1234")));

    var actions = vec_new();
    vec_push(actions, pair_new(str_from("MODE"), str_from("0666")));

    return udev_rule_new(str_from("99-yukti-test"), matches, actions);
}

fn test_render_rule() {
    test_group("udev_rules");

    var rule = make_test_rule();
    var rendered = render_rule(rule);
    assert(str_contains_cstr(rendered, "SUBSYSTEM"), "render has subsystem");
    assert(str_contains_cstr(rendered, "usb"), "render has usb");
    assert(str_contains_cstr(rendered, "MODE"), "render has mode");
    assert(str_contains_cstr(rendered, "0666"), "render has 0666");
    return 0;
}

fn test_validate_rule() {
    var rule = make_test_rule();
    assert(is_ok(validate_rule(rule)), "valid rule");

    # Empty name
    var bad_name = udev_rule_new(str_from(""), ur_match_attrs(rule), ur_actions(rule));
    assert(is_ok(validate_rule(bad_name)) == 0, "empty name invalid");

    # No matches
    var no_match = udev_rule_new(str_from("test"), vec_new(), ur_actions(rule));
    assert(is_ok(validate_rule(no_match)) == 0, "no matches invalid");

    # No actions
    var no_action = udev_rule_new(str_from("test"), ur_match_attrs(rule), vec_new());
    assert(is_ok(validate_rule(no_action)) == 0, "no actions invalid");
    return 0;
}

# ===================================================================
# Linux device manager tests
# ===================================================================

fn test_linux_dm() {
    test_group("linux");

    var mgr = linux_dm_new();
    assert(str_eq_cstr(ldm_sysfs_root(mgr), "/sys"), "dm root /sys");

    var mgr2 = linux_dm_with_root(str_from("/tmp/fake_sys"));
    assert(str_eq_cstr(ldm_sysfs_root(mgr2), "/tmp/fake_sys"), "dm custom root");

    # Get nonexistent
    var r = linux_dm_get(mgr, device_id_new_cstr("nonexistent"));
    assert(is_ok(r), "get ok");
    assert_eq(payload(r), 0, "get none");
    return 0;
}

